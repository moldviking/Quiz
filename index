</head>
<body>

<div class="quiz-container" id="main-container">

    <div class="sticky-action-bar" id="sticky-action-bar" style="display:none;">
        <button class="glass-exit-button" id="exit-button" onclick="openExitModal()" style="display:none;">
            <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
            Exit
        </button>
        <button class="later-button" id="later-button" onclick="markQuestionLater()">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-arrow-right-icon lucide-clock-arrow-right"><path d="M12 6v6l2 1"/><path d="M13.5 21.885A10 10 0 1 1 22 12"/><path d="M14 18h8"/><path d="m18 22 4-4-4-4"/></svg>
            Later
        </button>
        <button class="glass-exit-button" id="builder-back-button" onclick="openBuilderExitModal()" style="display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left-icon lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back
        </button>
        <button class="glass-exit-button glass-download-button" id="builder-download-button" onclick="openDownloadModal()" style="display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-download-icon lucide-download"><path d="M12 15V3"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="m7 10 5 5 5-5"/></svg>
            Download
        </button>
        <button class="glass-exit-button" id="results-done-button" onclick="confirmDone()" style="display:none; margin-left: auto;">
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Done
        </button>
    </div>

    <div id="mode-select-view" class="summary-card">
        <h2>Quiz Studio</h2>
        <p>Select an option to start your workspace session.</p>
        <div class="mode-choice-grid">
            <button class="mode-choice-button button-play" onclick="goToPlayUpload()">
                <canvas class="card-canvas-bg" data-svg-path="M8 5v14l11-7z"></canvas>
                <div class="mode-bottom-content">
                    <div class="mode-choice-header">
                        <div class="mode-icon-container">
                            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </div>
                        <span class="mode-title">Play Quiz</span>
                    </div>
                    <span class="mode-sub">Select a quiz and start answering.</span>
                </div>
            </button>
            <button class="mode-choice-button button-check" onclick="triggerCheckAnswers()">
                <div id="continue-checking-badge" onclick="resumeSession(event, 'check_answers')" style="display: none; position: absolute; top: 16px; right: 16px; background: rgba(0, 0, 0, 0.4); color: white; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; backdrop-filter: blur(4px); border: 1px solid rgba(255, 255, 255, 0.2); z-index: 10; pointer-events: auto; cursor: pointer;">Continue Checking</div>
                <canvas class="card-canvas-bg" data-svg-path="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"></canvas>
                <div class="mode-bottom-content">
                    <div class="mode-choice-header">
                        <div class="mode-icon-container">
                            <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
                        </div>
                        <span class="mode-title">Check Answers</span>
                    </div>
                    <span class="mode-sub">Evaluate a student's submitted results file.</span>
                </div>
            </button>
            <button class="mode-choice-button button-create" onclick="triggerCreateQuiz()">
                <div id="continue-editing-badge" onclick="resumeSession(event, 'builder')" style="display: none; position: absolute; top: 16px; right: 16px; background: rgba(0, 0, 0, 0.4); color: white; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; backdrop-filter: blur(4px); border: 1px solid rgba(255, 255, 255, 0.2); z-index: 10; pointer-events: auto; cursor: pointer;">Continue Editing</div>
                <canvas class="card-canvas-bg" data-svg-path="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"></canvas>
                <div class="mode-bottom-content">
                    <div class="mode-choice-header">
                        <div class="mode-icon-container">
                            <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                        </div>
                        <span class="mode-title">Create Quiz</span>
                    </div>
                    <span class="mode-sub">Build a quiz with your own questions.</span>
                </div>
            </button>
            <button class="mode-choice-button button-edit" onclick="triggerBuilderUpload()">
                <div id="continue-editing-edit-badge" onclick="resumeSession(event, 'builder')" style="display: none; position: absolute; top: 16px; right: 16px; background: rgba(0, 0, 0, 0.4); color: white; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; backdrop-filter: blur(4px); border: 1px solid rgba(255, 255, 255, 0.2); z-index: 10; pointer-events: auto; cursor: pointer;">Continue Editing</div>
                <canvas class="card-canvas-bg" data-svg-path="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"></canvas>
                <div class="mode-bottom-content">
                    <div class="mode-choice-header">
                        <div class="mode-icon-container">
                            <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                        </div>
                        <span class="mode-title">Edit Quiz</span>
                    </div>
                    <span class="mode-sub">Update or tweak questions.</span>
                </div>
            </button>
        </div>

    </div>
    
    <div id="upcoming-exam-pill" class="upcoming-exam-pill" style="display:none;" onclick="document.getElementById('exam-ready-modal').classList.add('active')">
        <div class="exam-pill-content">
            <span class="exam-pill-name" id="exam-pill-name">Quiz Name</span>
            <span class="exam-pill-timer" id="exam-pill-timer">00:00</span>
        </div>
    </div>
    
    <input type="file" id="results-file-selector" accept=".zip" style="display:none;">
    <input type="file" id="file-selector" accept=".zip" style="display:none;">
    <input type="file" id="builder-file-selector" accept=".zip" style="display:none;">

    <div id="quiz-game" style="display: none;">
        <div class="header-info">
            <div class="header-top">
                <p class="quiz-name" id="display-name">Loading...</p>
                <div style="text-align: right; display: flex; flex-direction: column; align-items: flex-end;">
                    <div id="timer-display-play" style="display: none; font-variant-numeric: tabular-nums; font-weight: 600; font-size: 13px; color: var(--text-secondary); margin-bottom: 2px;">00:00:00</div>
                    <p class="progress" id="progress">Question 1 of 3</p>
                </div>
            </div>
            <p class="quiz-description" id="display-description"></p>
        </div>
        <div class="play-question-header" style="display: flex; flex-direction: row; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 24px;">
            <div style="flex: 1; min-width: 0;">
                <h2 id="question-text" style="margin-top: 0;">Loading...</h2>
                <p class="play-points-badge" id="play-points" style="display:none;"></p>
                <p class="multi-select-hint" id="multi-select-hint" style="display:none; margin-top: 10px;">
                    <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    Select all answers that apply
                </p>
            </div>
            <div id="play-question-image-wrap" class="option-image-wrap" style="display:none; cursor: zoom-in; width: 140px; height: 140px;" title="Nagyításhoz kattints ide">
                <img id="play-question-image" class="option-image" src="" alt="Question Image" />
            </div>
        </div>
        
        <div class="options-container" id="options"></div>
        <button class="next-button" id="next-button" disabled onclick="handleMainAction()">Check</button>
    </div>
    
    <div id="quiz-results" class="summary-card" style="display: none;">
        <div style="display: flex; align-items: center; justify-content: flex-start; gap: 16px; margin-bottom: 24px;">
            <div class="score-circle" id="final-score" style="margin: 0; width: 80px; height: 80px; font-size: 24px; flex-shrink: 0;">0%</div>
            <div style="display: flex; flex-direction: column; justify-content: center;">
                <h2 id="result-status" style="margin: 0; text-align: left;">Results</h2>
                <p id="detailed-results" style="margin: 4px 0 0 0; text-align: left; font-size: 14px; color: var(--text-secondary);"></p>
            </div>
        </div>
        
        <div class="review-area" id="review-list"></div>
    </div>

    <div id="teacher-results-view" class="summary-card" style="display: none;">
        <h2 id="teacher-result-title" style="margin-bottom: 4px;">Student Results</h2>
        <p id="teacher-result-subtitle" style="font-size: 13px; color: var(--text-secondary); margin-bottom: 16px;"></p>
        <div style="display: flex; align-items: center; justify-content: flex-start; gap: 16px; margin-bottom: 24px;">
            <div class="score-circle" id="teacher-final-score" style="margin: 0; width: 80px; height: 80px; font-size: 24px; flex-shrink: 0;">0%</div>
            <div style="display: flex; flex-direction: column; justify-content: center;">
                <h2 id="teacher-result-status" style="margin: 0; text-align: left;">Results</h2>
                <p id="teacher-detailed-results" style="margin: 4px 0 0 0; text-align: left; font-size: 14px; color: var(--text-secondary);"></p>
            </div>
        </div>
        <div class="review-area" id="teacher-review-list"></div>
    </div>

    <div id="builder-view" style="display: none;">
        <h2>Quiz Studio Builder</h2>

        <div class="builder-meta-card">
            <div id="builder-quiz-name" class="text-input builder-meta-input" contenteditable="true" data-placeholder="TITLE"></div>
            <div class="builder-meta-separator"></div>
            <div id="builder-quiz-description" class="textarea-input builder-meta-textarea" contenteditable="true" data-placeholder="Summary"></div>
        </div>

        <div class="builder-meta-card options-card" id="builder-options-card">

            <div class="options-content-grid">
                <div class="options-content-wrapper">
                    <div class="options-content" id="options-content">
                        <div class="options-island-grid">
                            <div class="options-island" id="island-class-topic" onclick="handleClassTopicClick(event)" style="cursor: pointer; min-height: 172px;">
                                <div class="island-content-wrapper" style="width: 100%; display: flex; flex-direction: column;">
                                <div class="options-island-title" style="margin-bottom: 0; display: flex; justify-content: space-between; align-items: center;">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <div class="island-icon-box" style="background-color: var(--apple-blue); color: #fff;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v8l3-3 3 3V2"/><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
                                        </div>
                                        <span style="color: var(--text-secondary);"><span style="color: var(--text-main);">Overview</span></span>
                                    </div>
                                    <button id="class-topic-done-button" onclick="collapseClassTopic(event)" style="display: none; background: rgba(0, 122, 255, 0.1); color: var(--apple-blue); border: none; border-radius: 12px; padding: 4px 12px; font-size: 13px; font-weight: 600; cursor: pointer;">Done</button>
                                </div>
                                
                                <div class="island-accordion-wrapper" style="display: grid; grid-template-columns: 1fr;">
                                <div id="class-topic-collapsed-summary" class="island-accordion open-summary" style="grid-column: 1; grid-row: 1;">
                                    <div class="island-accordion-inner" style="display: flex; flex-direction: column; gap: 12px;">
                                        <div style="font-size: 14px; color: var(--text-secondary); display: flex; flex-direction: column; gap: 4px;">
                                            <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Class</span>
                                            <span id="summary-class-val" style="color: var(--text-secondary); font-weight: 500; font-size: 15px;"><span>Empty</span></span>
                                        </div>
                                        <div style="font-size: 14px; color: var(--text-secondary); display: flex; flex-direction: column; gap: 4px;">
                                            <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Topic</span>
                                            <span id="summary-topic-val" style="color: var(--text-secondary); font-weight: 500; font-size: 15px;"><span>Empty</span></span>
                                        </div>
                                    </div>
                                </div>

                                <div id="class-topic-fields" class="island-accordion" style="grid-column: 1; grid-row: 1;">
                                    <div class="island-accordion-inner">
                                    <div class="topic-grid-1">
                                        <div>
                                            <input type="text" id="meta-school" class="text-input" placeholder="School" oninput="saveBuilderState();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                        <div>
                                            <input type="text" id="meta-classroom" class="text-input" placeholder="Room" oninput="saveBuilderState();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                        <div>
                                            <input type="text" id="meta-grade" class="text-input" placeholder="Grade" oninput="saveBuilderState(); updateClassTopicSummary();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                        <div>
                                            <input type="text" id="meta-section" class="text-input" placeholder="Section" oninput="saveBuilderState(); updateClassTopicSummary();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                    </div>
                                    <div class="topic-grid-2">
                                        <div>
                                            <input type="text" id="meta-subject" class="text-input" placeholder="Subject" oninput="saveBuilderState();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                        <div>
                                            <input type="text" id="meta-topic" class="text-input" placeholder="Topic" oninput="saveBuilderState(); updateClassTopicSummary();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                        <div>
                                            <input type="text" id="meta-version" class="text-input" placeholder="Ver." oninput="saveBuilderState();" style="margin-bottom: 0; padding: 10px 10px;">
                                        </div>
                                    </div>
                                    </div>
                                </div>
                                </div>
                                </div>
                            </div>
                            <div class="options-island" id="island-grading" onclick="handleGradingClick(event)" style="cursor: pointer; overflow: visible; min-height: 172px;">
                                <div class="island-content-wrapper" style="width: 100%; display: flex; flex-direction: column;">
                                <div class="options-island-title" style="margin-bottom: 0; display: flex; justify-content: space-between; align-items: center;">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <div class="island-icon-box" style="background-color: #34C759; color: #fff;">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/></svg>
                                        </div>
                                        <span style="color: var(--text-secondary);"><span style="color: var(--text-main);">Grading</span></span>
                                    </div>
                                    <button id="grading-done-button" onclick="collapseGrading(event)" style="display: none; background: rgba(0, 122, 255, 0.1); color: var(--apple-blue); border: none; border-radius: 12px; padding: 4px 12px; font-size: 13px; font-weight: 600; cursor: pointer;">Done</button>
                                </div>

                                <div class="island-accordion-wrapper" style="display: grid; grid-template-columns: 1fr;">
                                <div id="grading-collapsed-summary" class="island-accordion open-summary" style="grid-column: 1; grid-row: 1;">
                                    <div class="island-accordion-inner" style="display: flex; flex-direction: column; gap: 12px;">
                                        <div style="font-size: 14px; color: var(--text-secondary); display: flex; flex-direction: column; gap: 4px;">
                                            <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Grading Type</span>
                                            <span id="summary-grading-type-val" style="color: var(--text-secondary); font-weight: 500; font-size: 15px;"><span style="color: var(--text-main);">Pass or Fail</span></span>
                                        </div>
                                        <div style="font-size: 14px; color: var(--text-secondary); display: flex; flex-direction: column; gap: 4px;">
                                            <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Settings</span>
                                            <span id="summary-grading-settings-val" style="color: var(--text-secondary); font-weight: 500; font-size: 15px;"><span style="color: var(--text-main);">60% Passing Score</span></span>
                                        </div>
                                    </div>
                                </div>

                                <div id="grading-fields" class="island-accordion" style="grid-column: 1; grid-row: 1;">
                                    <div class="island-accordion-inner">
                                    <div class="access-wrapper">
                                        <div class="access-sidebar-container">
                                            <div class="access-segmented-control" id="grading-segmented-control" style="--idx: 0;">
                                                <div class="access-slider" id="grading-slider"></div>
                                                <button class="access-segmented-button active" id="grading-button-pass_fail" onclick="selectGradingType('pass_fail')">Pass or Fail</button>
                                                <button class="access-segmented-button" id="grading-button-grouped_grades" onclick="selectGradingType('grouped_grades')">Grouped</button>
                                                <button class="access-segmented-button" id="grading-button-percentage" onclick="selectGradingType('percentage')">Percentage</button>
                                            </div>
                                        </div>
                                        <div id="grading-right-panel" style="position: relative; height: 100%; min-width: 0;">
                                            <div id="grade-slider-wrapper" style="margin-bottom: 0;">
                                                <label class="field-label" id="grade-label">Passing Score</label>
                                                <div style="margin-top: 8px;">
                                                    <div class="grade-capsule grade-success passing-capsule" id="capsule-passfail" onclick="openScaleStepperPopover('passing', 'pass', event)" style="padding: 0 16px; gap: 8px;">
                                                        <span style="font-size: 15px; font-weight: 500; color: var(--text-main);">Score at least</span>
                                                        <div style="width: 96px; display: flex; justify-content: center; height: 100%; align-items: center;">
                                                            <span class="grade-capsule-val" id="bounds-passing-pass" data-val="60">60%</span>
                                                        </div>
                                                        <span style="font-size: 15px; font-weight: 500; color: var(--text-main);">to pass.</span>
                                                    </div>
                                                    <div class="grade-capsule grade-success passing-capsule" id="capsule-percentage" onclick="openScaleStepperPopover('percentage', 'pass', event)" style="padding: 0 16px; gap: 8px; display: none;">
